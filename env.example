# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM API CREDENTIALS
# Obtain from https://my.telegram.org → API Development Tools
# ─────────────────────────────────────────────────────────────────────────────
API_ID=1234567
API_HASH=your_32_character_api_hash_here

# ─────────────────────────────────────────────────────────────────────────────
# BOT TOKEN
# Obtain from @BotFather on Telegram → /newbot
# ─────────────────────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# ─────────────────────────────────────────────────────────────────────────────
# MONGODB CONNECTION STRING
# Railway: copy from the MongoDB service "Connect" tab (MONGO_URL variable)
# Local:   mongodb://localhost:27017/telegram_bot
# ─────────────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/telegram_bot

# ─────────────────────────────────────────────────────────────────────────────
# CHANNEL / CHAT IDs
# Must be integer IDs — use @userinfobot to find them.
# SOURCE_CHANNEL_ID : the private storage channel the bot reads from
# TARGET_CHAT_ID    : the public channel or group the bot posts into
# ─────────────────────────────────────────────────────────────────────────────
SOURCE_CHANNEL_ID=-1001234567890
TARGET_CHAT_ID=-1009876543210

# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC CHANNEL LINK
# Shown to users who send /start to the bot
# ─────────────────────────────────────────────────────────────────────────────
PUBLIC_CHANNEL_LINK=https://t.me/your_public_channel

# ─────────────────────────────────────────────────────────────────────────────
# CONTENT SETTINGS
# FIXED_CAPTION : text appended to every post caption
# WATERMARK     : short tag (can be same as or part of fixed caption)
# Use \n for line breaks
# ─────────────────────────────────────────────────────────────────────────────
FIXED_CAPTION=🔥 Premium Content\nJoin: @your_public_channel
WATERMARK=@your_public_channel

# ─────────────────────────────────────────────────────────────────────────────
# SCHEDULING
# DAILY_LIMIT           : max posts per calendar day
# SEND_INTERVAL_SECONDS : gap between posts in seconds (1800 = 30 minutes)
# START_MESSAGE_ID      : message ID in source channel to begin scanning from
# TIMEZONE              : for daily counter reset (e.g. UTC, America/New_York)
# ─────────────────────────────────────────────────────────────────────────────
DAILY_LIMIT=20
SEND_INTERVAL_SECONDS=1800
START_MESSAGE_ID=1
TIMEZONE=UTC

# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY INTERNAL (set automatically by Dockerfile — do not change here)
# SESSION_DIR=/app/sessions
# ─────────────────────────────────────────────────────────────────────────────
