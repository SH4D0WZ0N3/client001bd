# .env.example
# --- Telegram API Credentials ---
# Get these from my.telegram.org
API_ID=1234567
API_HASH=your_api_hash

# --- Telegram Bot Token ---
# Get this from @BotFather
BOT_TOKEN=your_bot_token

# --- MongoDB Connection ---
MONGO_URI=mongodb://localhost:27017/telegram_premium_bot

# --- Channel/Chat IDs ---
# Must be integer IDs (e.g., -1001234567890)
SOURCE_CHANNEL_ID=
TARGET_CHAT_ID=

# --- Bot Configuration ---
# A public link to your channel for the /start command reply
PUBLIC_CHANNEL_LINK=https://t.me/your_public_channel

# --- Content Settings ---
# This text will be appended to the original caption.
# Use \n for new lines.
FIXED_CAPTION="🔥 Premium Content\nJoin: @your_public_channel"
WATERMARK="@your_public_channel"

# --- Scheduling Settings ---
# Maximum number of posts to send per day
DAILY_LIMIT=20
# Interval between posts in seconds (e.g., 1800 = 30 minutes)
SEND_INTERVAL_SECONDS=1800

# --- Initial Bootstrap Settings ---
# The message ID in the source channel to start copying from.
# The bot will scan from this message onwards on first run.
START_MESSAGE_ID=1

# --- Timezone ---
# For daily counter resets (e.g., "UTC", "America/New_York")
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC